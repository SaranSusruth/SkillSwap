# Copy this file to .env and fill in your values

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/skillswap

# Or MongoDB Atlas (replace with your connection string)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/skillswap?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_123456

# CORS Configuration
# For local development: http://localhost:3000,http://localhost:5173
# For Vercel deployment: https://your-vercel-domain.vercel.app
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
# Optional regex patterns for dynamic deployment URLs (comma-separated)
# Example supports Vercel preview domains starting with skill-swap
CORS_ORIGIN_REGEX=^https:\/\/skill-swap.*\.vercel\.app$

# App Configuration
APP_NAME=SkillSwap
APP_VERSION=1.0.0
